# ── Required ──────────────────────────────────────────────────────────────────

# Your Forest Admin environment secret (64-char hex string).
# Found in app.forestadmin.com → Settings → Environments → your environment.
FOREST_ENV_SECRET=

# JWT secret shared with your Forest Admin agent (must match authSecret in your agent config).
FOREST_AUTH_SECRET=

# URL where your Forest Admin agent is reachable from this executor.
# If both run on the same host: http://localhost:3351
# If the executor runs in Docker and the agent runs on the host: http://host.docker.internal:3351
AGENT_URL=

# Postgres connection string.
# Remove this line (or use --in-memory) to run without a database (state lost on restart).
DATABASE_URL=postgres://user:password@localhost:5432/mydb

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to "true" if your database requires TLS (e.g. AWS RDS, Supabase, Railway).
# DATABASE_SSL=false

# Port the executor's HTTP server listens on.
# HTTP_PORT=3400

# Forest Admin API URL. Override only for self-hosted environments.
# FOREST_SERVER_URL=https://api.forestadmin.com

# How often the executor polls the orchestrator for new steps (seconds).
# POLLING_INTERVAL_S=30

# Maximum time a single workflow step is allowed to run (seconds).
# STEP_TIMEOUT_S=300

# Maximum time to wait for a single AI provider call (seconds).
# AI_INVOKE_TIMEOUT_S=30

# Maximum number of steps auto-executed in a single chain before yielding back to polling.
# MAX_CHAIN_DEPTH=50

# Collection schema cache TTL (seconds). Lower values pick up schema changes faster.
# SCHEMA_CACHE_TTL_S=600

# Graceful shutdown timeout (seconds): how long to wait for in-flight steps to finish.
# STOP_TIMEOUT_S=30

# Log verbosity: Debug | Info | Warn | Error
# LOG_LEVEL=Info
